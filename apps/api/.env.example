# Database Configuration
DATABASE_URL=postgresql://user:password@localhost:5432/blogdb?sslmode=disable

# Server Configuration
PORT=8080

# JWT Authentication
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRATION_HOUR=24

# CORS Configuration
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# SMTP Email Configuration
# For MailHog (local testing):
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASS=
SMTP_FROM=Blog API <no-reply@blogapi.com>

# For Gmail (production):
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASS=your-app-password
# SMTP_FROM=Your App <no-reply@yourapp.com>

# Frontend URL (for email links)
FRONTEND_URL=http://localhost:3000

# Docker PostgreSQL Configuration (for docker-compose)
POSTGRES_USER=bloguser
POSTGRES_PASSWORD=blogpassword
POSTGRES_DB=blogdb

# ============================
# Storage Configuration
# ============================

# Storage type: "local" or "s3"
STORAGE_TYPE=local

# Base URL for the application (used to generate file URLs)
BASE_URL=http://localhost:8080

# Local Storage Settings (when STORAGE_TYPE=local)
LOCAL_UPLOAD_DIR=./uploads

# S3 Storage Settings (when STORAGE_TYPE=s3)
# AWS S3 Configuration
AWS_S3_REGION=us-east-1
AWS_S3_BUCKET=your-bucket-name
AWS_ACCESS_KEY_ID=your-access-key-id
AWS_SECRET_ACCESS_KEY=your-secret-access-key

# Optional: Custom S3 Endpoint (for MinIO, DigitalOcean Spaces, etc.)
# Leave empty for standard AWS S3
# Examples:
# AWS_S3_ENDPOINT=https://nyc3.digitaloceanspaces.com    # DigitalOcean Spaces
# AWS_S3_ENDPOINT=http://localhost:9000                   # MinIO (local)
# AWS_S3_ENDPOINT=https://s3.wasabisys.com               # Wasabi
AWS_S3_ENDPOINT=
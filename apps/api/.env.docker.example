# Docker Environment Configuration
# This file is used by docker-compose.yml
# Copy this file to .env.docker and update with your actual values

# PostgreSQL Configuration
POSTGRES_USER=bloguser
POSTGRES_PASSWORD=change-this-password
POSTGRES_DB=blogdb

# Database URL (for API container)
DATABASE_URL=postgresql://user:password@localhost:5432/blogdb?sslmode=disable

# Server Configuration
PORT=8080

# JWT Configuration
JWT_SECRET=change-this-to-a-strong-256-bit-key
JWT_EXPIRATION_HOUR=24

# CORS Configuration
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost

# Mail Configuration (MailHog)
SMTP_HOST=mailhog
SMTP_PORT=1025
SMTP_USER=
SMTP_PASS=
SMTP_FROM=Blog API <no-reply@blogapi.com>

# Frontend URL
FRONTEND_URL=http://localhost:3000

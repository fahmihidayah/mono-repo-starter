type I{{ $modelName }}Service interface {
    Create(ctx context.Context, req *request.Create{{ $modelName }}Request) (*domain.{{ $modelName }}, error)
    GetAll(ctx context.Context, page, limit int) ([]domain.{{ $modelName }}, int64, error)
    GetByID(ctx context.Context, id {{ $pkType }}) (*domain.{{ $modelName }}, error)
    {{- range .Fields }}{{ if eq .Name "Slug" }}
    GetBySlug(ctx context.Context, slug string) (*domain.{{ $modelName }}, error)
    {{- end }}{{ end }}
    Update(ctx context.Context, id {{ $pkType }}, req *request.Create{{ $modelName }}Request) (*domain.{{ $modelName }}, error)
    Delete(ctx context.Context, id {{ $pkType }}) error
    DeleteAll(ctx context.Context, ids []{{ $pkType }}) error
    
    // React Admin specific methods
    GetWithQueryParams(ctx context.Context, queryParams *utils.QueryParams) ([]*domain.{{ $modelName }}, int64, error)
    GetByIDs(ctx context.Context, ids []{{ $pkType }}) ([]domain.{{ $modelName }}, error)
    UpdateMany(ctx context.Context, ids []{{ $pkType }}, updates map[string]interface{}) ([]{{ $pkType }}, error)
}

type {{ $modelName }}ServiceImpl struct {
    repo      repository.I{{ $modelName }}Repository
    validator *validator.Validate
    config    *config.Config
}

func {{ $modelName }}ServiceProvider(
    repo repository.I{{ $modelName }}Repository,
    config *config.Config,
) I{{ $modelName }}Service {
    return &{{ $modelName }}ServiceImpl{
        repo:      repo,
        validator: validator.New(),
        config:    config,
    }
}

func (s *{{ $modelName }}ServiceImpl) Create(ctx context.Context, req *request.Create{{ $modelName }}Request) (*domain.{{ $modelName }}, error) {
    if err := s.validator.Struct(req); err != nil {
        return nil, err
    }

    data := &domain.{{ $modelName }}{
        {{- range .Fields }}
        {{- if and (not .PrimaryKey) (not .AutoIncrement) (not .AutoNow) (not .AutoNowAdd) }}
        {{- if eq .Name "ID" }}
        ID: utils.GenerateUUID(),
        {{- else if eq .Name "Slug" }}
        Slug: utils.GenerateSlug(req.Name),
        {{- else if .Request }}
        {{ .Name }}: req.{{ .Name }},
        {{- end }}
        {{- end }}
        {{- end }}
    }

    if err := s.repo.Create(ctx, data); err != nil {
        return nil, err
    }

    return data, nil
}

func (s *{{ $modelName }}ServiceImpl) GetAll(ctx context.Context, page, limit int) ([]domain.{{ $modelName }}, int64, error) {
    if page < 1 { page = 1 }
    if limit < 1 || limit > 100 { limit = 10 }

    offset := (page - 1) * limit

    data, err := s.repo.GetAll(ctx, limit, offset)
    if err != nil {
        return nil, 0, err
    }

    count, err := s.repo.Count(ctx)
    if err != nil {
        return nil, 0, err
    }

    return data, count, nil
}

func (s *{{ $modelName }}ServiceImpl) GetByID(ctx context.Context, id {{ $pkType }}) (*domain.{{ $modelName }}, error) {
    return s.repo.GetByID(ctx, id)
}

{{- range .Fields }}{{ if eq .Name "Slug" }}
func (s *{{ $modelName }}ServiceImpl) GetBySlug(ctx context.Context, slug string) (*domain.{{ $modelName }}, error) {
    return s.repo.FindBySlug(ctx, slug)
}
{{- end }}{{ end }}

func (s *{{ $modelName }}ServiceImpl) Update(ctx context.Context, id {{ $pkType }}, req *request.Create{{ $modelName }}Request) (*domain.{{ $modelName }}, error) {
    if err := s.validator.Struct(req); err != nil {
        return nil, err
    }

    existing, err := s.repo.GetByID(ctx, id)
    if err != nil {
        return nil, err
    }

    // Map fields from request to existing domain model
    {{- range .Fields }}
    {{- if and .Request (not .PrimaryKey) }}
    {{- if eq .Name "Slug" }}
    existing.Slug = utils.GenerateSlug(req.Name)
    {{- else }}
    existing.{{ .Name }} = req.{{ .Name }}
    {{- end }}
    {{- end }}
    {{- end }}

    if err := s.repo.Update(ctx, existing); err != nil {
        return nil, err
    }

    return existing, nil
}

func (s *{{ $modelName }}ServiceImpl) Delete(ctx context.Context, id {{ $pkType }}) error {
    _, err := s.repo.GetByID(ctx, id)
    if err != nil {
        return err
    }
    return s.repo.Delete(ctx, id)
}

func (s *{{ $modelName }}ServiceImpl) DeleteAll(ctx context.Context, ids []{{ $pkType }}) error {
    if len(ids) == 0 {
        return errors.New("IDs array cannot be empty")
    }
    return s.repo.DeleteAll(ctx, ids)
}

func (s *{{ $modelName }}ServiceImpl) GetWithQueryParams(ctx context.Context, queryParams *utils.QueryParams) ([]*domain.{{ $modelName }}, int64, error) {
    data, err := s.repo.GetWithQuery(ctx, queryParams)
    if err != nil {
        return nil, 0, err
    }

    count, err := s.repo.CountByQuery(ctx, queryParams)
    if err != nil {
        return nil, 0, err
    }

    return data, count, nil
}

func (s *{{ $modelName }}ServiceImpl) GetByIDs(ctx context.Context, ids []{{ $pkType }}) ([]domain.{{ $modelName }}, error) {
    if len(ids) == 0 {
        return []domain.{{ $modelName }}{}, nil
    }

    res := s.repo.GetAllIds(ctx, ids)
    
    // Convert pointer slice to value slice
    final := make([]domain.{{ $modelName }}, 0, len(res))
    for _, item := range res {
        final = append(final, *item)
    }

    return final, nil
}

func (s *{{ $modelName }}ServiceImpl) UpdateMany(ctx context.Context, ids []{{ $pkType }}, updates map[string]interface{}) ([]{{ $pkType }}, error) {
    if len(ids) == 0 {
        return nil, errors.New("IDs array cannot be empty")
    }

    updatedIDs := make([]{{ $pkType }}, 0, len(ids))
    for _, id := range ids {
        existing, err := s.repo.GetByID(ctx, id)
        if err != nil {
            continue
        }

        // Simple mapping for UpdateMany (extendable)
        {{- range .Fields }}
        {{- if .Request }}
        if val, ok := updates["{{ .JSON }}"].({{ .Type }}); ok {
            existing.{{ .Name }} = val
            {{- if eq .Name "Name" }}
            existing.Slug = utils.GenerateSlug(val)
            {{- end }}
        }
        {{- end }}
        {{- end }}

        if err := s.repo.Update(ctx, existing); err == nil {
            updatedIDs = append(updatedIDs, id)
        }
    }

    return updatedIDs, nil
}
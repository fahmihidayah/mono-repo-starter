package controller

import (
    "encoding/json"
    "log"
    "net/http"

    request "{{ removeWhiteSpace .Project.Package }}/internal/data/request/{{ .Name | lower }}s"
    "{{ removeWhiteSpace .Project.Package }}/internal/service"
)

{{- $modelName := .Name }}
{{- $lowerModelName := .Name | lower }}
{{- $pkType := "string" }}
{{- range .Fields }}{{ if .PrimaryKey }}{{ $pkType = .Type }}{{ end }}{{ end }}

// {{ $modelName }}Controller handles {{ $modelName }} endpoints with React Admin compatibility
type {{ $modelName }}Controller struct {
    BaseController
    {{ $lowerModelName }}Service service.I{{ $modelName }}Service
}

// {{ $modelName }}ControllerProvider creates a new {{ $modelName }}Controller
func {{ $modelName }}ControllerProvider({{ $lowerModelName }}Service service.I{{ $modelName }}Service) *{{ $modelName }}Controller {
    return &{{ $modelName }}Controller{
        {{ $lowerModelName }}Service: {{ $lowerModelName }}Service,
    }
}

// GetList handles React Admin getList - GET /{{ $lowerModelName }}s?sort=[...]&range=[...]&filter={...}
func (c *{{ $modelName }}Controller) GetList(w http.ResponseWriter, r *http.Request) {
    log.Printf("[{{ $modelName }}Controller.GetList] Request URL: %s", r.URL.String())

    params, err := c.ParseQueryParams(r)
    if err != nil {
        c.SendBadRequest(w, err.Error())
        return
    }

    // Check for getMany case (filter contains "ids")
    if ids, hasIDs := params.GetFilterIDs(); hasIDs {
        c.getMany(w, r, ids)
        return
    }

    results, total, err := c.{{ $lowerModelName }}Service.GetWithQueryParams(r.Context(), params)
    if err != nil {
        c.SendInternalError(w, err.Error())
        return
    }

    c.SendList(w, results, total)
}

// getMany handles React Admin getMany - GET /{{ $lowerModelName }}s?filter={"ids":[...]}
func (c *{{ $modelName }}Controller) getMany(w http.ResponseWriter, r *http.Request, ids []{{ $pkType }}) {
    results, err := c.{{ $lowerModelName }}Service.GetByIDs(r.Context(), ids)
    if err != nil {
        c.SendInternalError(w, err.Error())
        return
    }

    c.SendOne(w, results)
}

// GetOne handles React Admin getOne - GET /{{ $lowerModelName }}s/:id
func (c *{{ $modelName }}Controller) GetOne(w http.ResponseWriter, r *http.Request) {
    id := c.GetIDFromURL(r)
    if id == "" {
        c.SendBadRequest(w, "ID is required")
        return
    }

    {{- if eq $pkType "uint" }}
    // Convert string ID from URL to uint if necessary
    // idUint := castToUint(id) 
    {{- end }}

    result, err := c.{{ $lowerModelName }}Service.GetByID(r.Context(), id)
    if err != nil {
        c.SendNotFound(w, err.Error())
        return
    }

    c.SendOne(w, result)
}

// Create handles React Admin create - POST /{{ $lowerModelName }}s
func (c *{{ $modelName }}Controller) Create(w http.ResponseWriter, r *http.Request) {
    var req request.Create{{ $modelName }}Request
    if err := c.DecodeJSONBody(r, &req); err != nil {
        c.SendBadRequest(w, "Invalid request body")
        return
    }

    result, err := c.{{ $lowerModelName }}Service.Create(r.Context(), &req)
    if err != nil {
        c.SendBadRequest(w, err.Error())
        return
    }

    c.SendOne(w, result)
}

// Update handles React Admin update - PUT /{{ $lowerModelName }}s/:id
func (c *{{ $modelName }}Controller) Update(w http.ResponseWriter, r *http.Request) {
    id := c.GetIDFromURL(r)
    if id == "" {
        c.SendBadRequest(w, "ID is required")
        return
    }

    var req request.Create{{ $modelName }}Request
    if err := c.DecodeJSONBody(r, &req); err != nil {
        c.SendBadRequest(w, "Invalid request body")
        return
    }

    result, err := c.{{ $lowerModelName }}Service.Update(r.Context(), id, &req)
    if err != nil {
        c.SendBadRequest(w, err.Error())
        return
    }

    c.SendOne(w, result)
}

// UpdateMany handles React Admin updateMany - PUT /{{ $lowerModelName }}s?filter={"id":[...]}
func (c *{{ $modelName }}Controller) UpdateMany(w http.ResponseWriter, r *http.Request) {
    params, err := c.ParseQueryParams(r)
    if err != nil {
        c.SendBadRequest(w, err.Error())
        return
    }

    ids, hasIDs := params.GetFilterIDs()
    if !hasIDs {
        c.SendBadRequest(w, "Missing id filter")
        return
    }

    var updates map[string]interface{}
    if err := c.DecodeJSONBody(r, &updates); err != nil {
        c.SendBadRequest(w, "Invalid request body")
        return
    }

    updatedIDs, err := c.{{ $lowerModelName }}Service.UpdateMany(r.Context(), ids, updates)
    if err != nil {
        c.SendBadRequest(w, err.Error())
        return
    }

    c.SendIDs(w, updatedIDs)
}

// Delete handles React Admin delete - DELETE /{{ $lowerModelName }}s/:id
func (c *{{ $modelName }}Controller) Delete(w http.ResponseWriter, r *http.Request) {
    id := c.GetIDFromURL(r)
    if id == "" {
        c.SendBadRequest(w, "ID is required")
        return
    }

    result, err := c.{{ $lowerModelName }}Service.GetByID(r.Context(), id)
    if err != nil {
        c.SendNotFound(w, err.Error())
        return
    }

    if err := c.{{ $lowerModelName }}Service.Delete(r.Context(), id); err != nil {
        c.SendBadRequest(w, err.Error())
        return
    }

    c.SendOne(w, result)
}

// DeleteMany handles React Admin deleteMany - DELETE /{{ $lowerModelName }}s?filter={"id":[...]}
func (c *{{ $modelName }}Controller) DeleteMany(w http.ResponseWriter, r *http.Request) {
    params, err := c.ParseQueryParams(r)
    if err != nil {
        c.SendBadRequest(w, err.Error())
        return
    }

    ids, hasIDs := params.GetFilterIDs()
    if !hasIDs {
        c.SendBadRequest(w, "Missing id filter")
        return
    }

    if err := c.{{ $lowerModelName }}Service.DeleteAll(r.Context(), ids); err != nil {
        c.SendBadRequest(w, err.Error())
        return
    }

    c.SendIDs(w, ids)
}
    "context"
    "errors"
    "fmt"

    "{{ removeWhiteSpace .Project.Package }}/internal/domain"
    "{{ removeWhiteSpace .Project.Package }}/internal/utils"
    "gorm.io/gorm"
)

{{- $modelName := .Name }}
{{- $lowerModelName := .Name | lower }}
{{- $pkType := "string" }}
{{- range .Fields }}{{ if .PrimaryKey }}{{ $pkType = .Type }}{{ end }}{{ end }}

type I{{ $modelName }}Repository interface {
    {{- /* Cek jika ada field slug untuk generate FindBySlug */ -}}
    {{- range .Fields }}{{ if eq .Name "Slug" }}
    FindBySlug(ctx context.Context, slug string) (*domain.{{ $modelName }}, error)
    {{- end }}{{ end }}
    Create(ctx context.Context, data *domain.{{ $modelName }}) error
    GetByID(ctx context.Context, id {{ $pkType }}) (*domain.{{ $modelName }}, error)
    GetAll(ctx context.Context, limit, offset int) ([]domain.{{ $modelName }}, error)
    GetAllIds(ctx context.Context, ids []{{ $pkType }}) []*domain.{{ $modelName }}
    GetWithQuery(ctx context.Context, queryParams *utils.QueryParams) ([]*domain.{{ $modelName }}, error)
    Update(ctx context.Context, data *domain.{{ $modelName }}) error
    Delete(ctx context.Context, id {{ $pkType }}) error
    DeleteAll(ctx context.Context, ids []{{ $pkType }}) error
    Count(ctx context.Context) (int64, error)
    CountByQuery(ctx context.Context, queryParams *utils.QueryParams) (int64, error)
}

type {{ $modelName }}RepositoryImpl struct {
    db *gorm.DB
}

func {{ $modelName }}RepositoryProvider(db *gorm.DB) I{{ $modelName }}Repository {
    return &{{ $modelName }}RepositoryImpl{db: db}
}

func (r *{{ $modelName }}RepositoryImpl) Create(ctx context.Context, data *domain.{{ $modelName }}) error {
    return r.db.WithContext(ctx).Create(data).Error
}

func (r *{{ $modelName }}RepositoryImpl) GetByID(ctx context.Context, id {{ $pkType }}) (*domain.{{ $modelName }}, error) {
    var data domain.{{ $modelName }}
    if err := r.db.WithContext(ctx).First(&data, "id = ?", id).Error; err != nil {
        if errors.Is(err, gorm.ErrRecordNotFound) {
            return nil, fmt.Errorf("{{ $lowerModelName }} not found")
        }
        return nil, err
    }
    return &data, nil
}

func (r *{{ $modelName }}RepositoryImpl) GetAll(ctx context.Context, limit, offset int) ([]domain.{{ $modelName }}, error) {
    var data []domain.{{ $modelName }}
    err := r.db.WithContext(ctx).Limit(limit).Offset(offset).Find(&data).Error
    return data, err
}

func (r *{{ $modelName }}RepositoryImpl) GetAllIds(ctx context.Context, ids []{{ $pkType }}) []*domain.{{ $modelName }} {
    var data []*domain.{{ $modelName }}
    r.db.WithContext(ctx).Where("id IN ?", ids).Find(&data)
    return data
}

func (r *{{ $modelName }}RepositoryImpl) GetWithQuery(ctx context.Context, queryParams *utils.QueryParams) ([]*domain.{{ $modelName }}, error) {
    var data []*domain.{{ $modelName }}
    tx := r.db.WithContext(ctx).Limit(queryParams.Limit).Offset(queryParams.Offset)

    if len(queryParams.Sort) >= 2 {
        tx = tx.Order(queryParams.Sort[0] + " " + queryParams.Sort[1])
    }

    for key, value := range queryParams.Filter {
        if key == "ids" || key == "id" {
            if ids, ok := queryParams.GetFilterIDs(); ok {
                tx = tx.Where("id IN ?", ids)
            }
        } else {
            if strValue, ok := value.(string); ok {
                tx = tx.Where(key+" LIKE ?", "%"+strValue+"%")
            }
        }
    }

    err := tx.Find(&data).Error
    return data, err
}

func (r *{{ $modelName }}RepositoryImpl) Delete(ctx context.Context, id {{ $pkType }}) error {
    result := r.db.WithContext(ctx).Delete(&domain.{{ $modelName }}{}, "id = ?", id)
    if result.Error != nil {
        return result.Error
    }
    if result.RowsAffected == 0 {
        return fmt.Errorf("{{ $lowerModelName }} not found")
    }
    return nil
}

func (r *{{ $modelName }}RepositoryImpl) DeleteAll(ctx context.Context, ids []{{ $pkType }}) error {
    result := r.db.WithContext(ctx).Where("id IN ?", ids).Delete(&domain.{{ $modelName }}{})
    if result.Error != nil {
        return result.Error
    }
    if result.RowsAffected == 0 {
        return fmt.Errorf("no {{ $lowerModelName }} found with the provided IDs")
    }
    return nil
}

func (r *{{ $modelName }}RepositoryImpl) Count(ctx context.Context) (int64, error) {
    var count int64
    err := r.db.WithContext(ctx).Model(&domain.{{ $modelName }}{}).Count(&count).Error
    return count, err
}

func (r *{{ $modelName }}RepositoryImpl) CountByQuery(ctx context.Context, queryParams *utils.QueryParams) (int64, error) {
    var count int64
    tx := r.db.WithContext(ctx).Model(&domain.{{ $modelName }}{})

    for key, value := range queryParams.Filter {
        if key == "ids" || key == "id" {
            if ids, ok := queryParams.GetFilterIDs(); ok {
                tx = tx.Where("id IN ?", ids)
            }
        } else {
            if strValue, ok := value.(string); ok {
                tx = tx.Where(key+" LIKE ?", "%"+strValue+"%")
            }
        }
    }

    err := tx.Count(&count).Error
    return count, err
}

func (r *{{ $modelName }}RepositoryImpl) Update(ctx context.Context, data *domain.{{ $modelName }}) error {
    result := r.db.WithContext(ctx).Save(data)
    if result.Error != nil {
        return result.Error
    }
    if result.RowsAffected == 0 {
        return fmt.Errorf("{{ $lowerModelName }} not found or no changes made")
    }
    return nil
}

{{- range .Fields }}{{ if eq .Name "Slug" }}
func (r *{{ $modelName }}RepositoryImpl) FindBySlug(ctx context.Context, slug string) (*domain.{{ $modelName }}, error) {
    var data domain.{{ $modelName }}
    if err := r.db.WithContext(ctx).Where("slug = ?", slug).First(&data).Error; err != nil {
        if errors.Is(err, gorm.ErrRecordNotFound) {
            return nil, fmt.Errorf("{{ $lowerModelName }} not found")
        }
        return nil, err
    }
    return &data, nil
}

# ============================================
# Monorepo .gitignore
# ============================================
# This gitignore covers the entire monorepo:
# - Root workspace
# - Go API (apps/api)
# - React Router Frontend (apps/frontend)
# - Shared packages

# ============================================
# Dependencies
# ============================================
node_modules/
.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/sdks
!.yarn/versions
vendor/

# ============================================
# Environment Variables
# ============================================
.env
.env.local
.env.*.local
.env.development.local
.env.test.local
.env.production.local
.env.docker

# ============================================
# Build Outputs
# ============================================
# Next.js / React Router
.next/
.react-router/
out/
build/
dist/
.output/
.nuxt/
.cache/

# Go binaries
bin/
*.exe
*.exe~
*.dll
*.so
*.dylib

# ============================================
# Testing & Coverage
# ============================================
coverage/
*.lcov
.nyc_output
*.test
*.out
*.prof
coverage.html
coverage.out

# ============================================
# Logs
# ============================================
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*
logs/
build-errors.log

# ============================================
# Turbo
# ============================================
.turbo

# ============================================
# IDEs and Editors
# ============================================
# VSCode
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
*.code-workspace

# IntelliJ / GoLand / WebStorm
.idea/
*.iml
*.ipr
*.iws
out/

# Vim
*.swp
*.swo
*~
.vim/

# Emacs
*~
\#*\#
.\#*

# Sublime Text
*.sublime-project
*.sublime-workspace

# ============================================
# OS Files
# ============================================
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
Desktop.ini

# ============================================
# Temporary Files
# ============================================
*.tmp
*.temp
tmp/
temp/

# ============================================
# Deployment
# ============================================
.vercel
.netlify
.firebase/
.serverless/
.fusebox/

# ============================================
# Database
# ============================================
*.db
*.sqlite
*.sqlite3
*.db-shm
*.db-wal

# ============================================
# Go Specific
# ============================================
# Test binary, built with `go test -c`
*.test

# Output of the go coverage tool
*.out

# Go workspace file
go.work
go.work.sum

# Air - Live reload for Go
tmp/

# ============================================
# JavaScript/TypeScript Specific
# ============================================
# TypeScript cache
*.tsbuildinfo

# Optional npm cache directory
.npm

# Optional eslint cache
.eslintcache

# Optional stylelint cache
.stylelintcache

# Microbundle cache
.rpt2_cache/
.rts2_cache_cjs/
.rts2_cache_es/
.rts2_cache_umd/

# Optional REPL history
.node_repl_history

# Stores VSCode versions used for testing VSCode extensions
.vscode-test

# ============================================
# Security
# ============================================
*.pem
*.key
*.cert
*.crt
secrets/
.secrets

# ============================================
# Miscellaneous
# ============================================
# Local Netlify folder
.netlify

# SvelteKit
.svelte-kit

# Storybook
storybook-static

# Playwright
playwright-report/
test-results/

# Docusaurus
.docusaurus

# ============================================
# Claude Code
# ============================================
# Uncomment if you don't want to commit Claude settings
# .claude/
